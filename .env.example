# ── Database ──────────────────────────────────────────────────────────────────
DB_PASSWORD=changeme
DATABASE_URL=postgresql+asyncpg://postgres:changeme@db:5432/claude_proxy

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=change-me-to-64-random-hex-chars

# ── First admin user (created on first boot if no users exist) ────────────────
FIRST_ADMIN_USERNAME=admin
FIRST_ADMIN_EMAIL=admin@example.com
FIRST_ADMIN_PASSWORD=changeme123!

# ── Proxy behavior ────────────────────────────────────────────────────────────
# For local testing with mock — change to real API for production:
# ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_BASE_URL=http://mock-anthropic:8001
REQUEST_TIMEOUT_SECONDS=300.0
MAX_PROMPT_LOG_CHARS=50000

# Set to false for GDPR compliance (disables prompt/response content logging)
ENABLE_PROMPT_LOGGING=true

# ── Token settings ────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
